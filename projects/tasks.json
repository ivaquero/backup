{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: clang++ build OpenCV4",
            "command": "/usr/bin/clang++",
            "args": [
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-I",
                "/Users/integzz/.conda/envs/cpp/include",
                "-I",
                "/Users/integzz/.conda/envs/cpp/include/opencv4",
                "-L",
                "/Users/integzz/.conda/envs/cpp/lib",
                "-lopencv_core",
                "-lopencv_imgcodecs",
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build"
        }
    ]
}
