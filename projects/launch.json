{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug OpenCV (Conda)",
            "type": "cppdbg",
            "request": "launch",
            "targetArchitecture": "arm64",
            "program": "${fileDirname}/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "DYLD_LIBRARY_PATH",
                    "value": "${env:HOME}/.conda/envs/cpp/lib"
                }
            ],
            "MIMode": "lldb",
            "internalConsoleOptions": "openOnSessionStart"
        }
    ]
}
