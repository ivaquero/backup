      "",
      "    ruler = fig.add_axes(loc)",
      "    if orient == 'h':",
      "        cbar = f1.colorbar(sm, cax=ruler, orientation='horizontal')",
      "    if orient == 'v':",
      "        cbar = f1.colorbar(sm, cax=ruler, orientation='vertical')",
      "    cbar.ax.tick_params(labelsize=labelsize)",
      "",
      "    return cbar",
