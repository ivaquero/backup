{
  "files.autoGuessEncoding": true,
  "files.defaultLanguage": "markdown",
  "files.encoding": "utf8bom",
  "files.trimTrailingWhitespace": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.fontLigatures": true,
  "editor.fontSize": 18,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.inlineSuggest.enabled": true,
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.semanticHighlighting.enabled": true,
  "editor.wordWrap": "bounded",
  "editor.quickSuggestions": {
    "other": true,
    "comments": true,
    "strings": true
  },
  "editor.fontFamily": "FiraCode Nerd Font",
  // "editor.fontFamily": "FiraCode NF",
  "editor.inlayHints.fontFamily": "FiraCode Nerd Font",
  // "editor.inlayHints.fontFamily": "FiraCode NF",
  "debug.console.fontFamily": "FiraCode Nerd Font",
  // "debug.console.fontFamily": "FiraCode NF",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.sortOrder": "type",
  "diffEditor.wordWrap": "on",
  "extensions.autoUpdate": "onlyEnabledExtensions",
  "emmet.showSuggestionsAsSnippets": true,
  "git-graph.repository.sign.commits": true,
  "git-graph.repository.sign.tags": true,
  "git.alwaysShowStagedChangesResourceGroup": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.supportCancellation": true,
  "gitlens.advanced.messages": {
    "suppressCommitHasNoPreviousCommitWarning": true,
    "suppressGitMissingWarning": true
  },
  "gitlens.mode.active": "zen",
  "html.format.indentInnerHtml": true,
  "security.workspace.trust.untrustedFiles": "open",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.fontFamily": "FiraCode Nerd Font",
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.inheritEnv": false,
  "terminal.integrated.rightClickBehavior": "copyPaste",
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.showExitAlert": false,
  "terminal.integrated.splitCwd": "workspaceRoot",
  "terminal.integrated.tabs.focusMode": "singleClick",
  "terminal.integrated.tabs.hideCondition": "never",
  "terminal.integrated.wordSeparators": " ()[]{}',\"`─",
  "terminal.integrated.commandsToSkipShell": [
    "language-julia.interrupt"
  ],
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "path": "pwsh.exe",
      "args": []
    }
  },
  "terminal.integrated.profiles.osx": {
    "zsh": {
      "path": "zsh",
      "args": [
        "-l"
      ]
    }
  },
  "terminal.integrated.profiles.linux": {
    "zsh": {
      "path": "zsh",
      "args": [
        "-l"
      ]
    }
  },
  "window.restoreWindows": "all",
  "workbench.activityBar.iconClickBehavior": "toggle",
  "workbench.colorTheme": "Default Light+",
  "workbench.editor.enablePreviewFromCodeNavigation": true,
  "workbench.editor.enablePreviewFromQuickOpen": true,
  "workbench.editor.pinnedTabSizing": "compact",
  "workbench.editor.wrapTabs": true,
  "workbench.editorAssociations": {
    // "*.md": "markdown-notebook",
    "*.ipynb": "jupyter-notebook",
    "*.jpg": "imagePreview.previewEditor",
    "*.png": "imagePreview.previewEditor",
    "*.pdf": "latex-workshop-pdf-hook"
  },
  "workbench.iconTheme": "material-icon-theme",
  "workbench.list.smoothScrolling": true,
  "workbench.startupEditor": "newUntitledFile",
  "workbench.tree.indent": 8,
  "files.associations": {
    "*.condarc": "yaml",
    "*.m": "matlab"
  },
  "code-runner.runInTerminal": true,
  "code-runner.executorMap": {
    "c": "clang $dir$fileName -o $dir$fileNameWithoutExt && $dir$fileNameWithoutExt",
    "cpp": "clang++ -std=c++20 $dir$fileName -o $dir$fileNameWithoutExt && $dir$fileNameWithoutExt",
    "java": "javac $dir$fileName && java $dir$fileNameWithoutExt",
    "javascript": "deno fmt && deno run --allow-net $fullFileName",
    "julia": "julia eval $fullFileName",
    "python": "$(which python) -u $fullFileName",
    "rust": "rustc $dir$fileName && $dir$fileNameWithoutExt",
    "shell": "zsh $fullFileName",
  },
  "code-runner.fileDirectoryAsCwd": true,
  "code-runner.saveAllFilesBeforeRun": true,
  "code-runner.saveFileBeforeRun": false,
  "markdown-toc.anchorMode": "github.com",
  "markdown-toc.withLinks": true,
  "markdown.extension.italic.indicator": "*",
  "markdown.extension.print.theme": "light",
  "markdown.extension.syntax.decorationFileSizeLimit": 50000,
  "markdown.extension.tableFormatter.normalizeIndentation": true,
  "markdown.extension.toc.levels": "1..4",
  "markdown.extension.toc.orderedList": true,
  "markdown.extension.toc.plaintext": true,
  "markdown.preview.breaks": true,
  "markdown.preview.fontFamily": "consolas",
  "markdown.preview.fontSize": 16,
  "markdown.preview.linkify": true,
  "markdown.preview.markEditorSelection": true,
  "markdown.preview.openMarkdownLinks": "inEditor",
  "markdown.preview.scrollPreviewWithEditor": true,
  "markdown.preview.typographer": true,
  "mdtableeditor.commandViews": {
    "toolbar": [
      "MdTableEditor.changeAlignCenter",
      "MdTableEditor.changeAlignLeft",
      "MdTableEditor.changeAlignRight",
      "MdTableEditor.insertBottom",
      "MdTableEditor.insertLeft",
      "MdTableEditor.insertRight",
      "MdTableEditor.insertTop",
      "MdTableEditor.moveBottom",
      "MdTableEditor.moveLeft",
      "MdTableEditor.moveRight",
      "MdTableEditor.moveTop",
      "MdTableEditor.removeColumn",
      "MdTableEditor.removeRow",
    ],
    "context": [
      "MdTableEditor.changeAlignCenter",
      "MdTableEditor.changeAlignLeft",
      "MdTableEditor.changeAlignRight",
      "MdTableEditor.insertBottom",
      "MdTableEditor.insertLeft",
      "MdTableEditor.insertRight",
      "MdTableEditor.insertTop",
      "MdTableEditor.moveBottom",
      "MdTableEditor.moveLeft",
      "MdTableEditor.moveRight",
      "MdTableEditor.moveTop",
      "MdTableEditor.removeColumn",
      "MdTableEditor.removeRow",
    ]
  },
  "mdtableeditor.isAutoFormatterEnabled": true,
  "mdtableeditor.isTreeViewEnabled": true,
  "mdtableeditor.isIconMenuEnabled": true,
  "pandoc.docxOptString": "",
  "pandoc.htmlOptString": "--standalone --mathjax --shift-heading-level-by=-1",
  "pandoc.pdfOptString": "--pdf-engine=xelatex -V CJKmainfont=\"Arial Unicode MS\"",
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "notebook.diff.enablePreview": false,
  "notebook.diff.ignoreOutputs": true,
  "notebook.lineNumbers": "on",
  "notebook.markup.fontSize": 16,
  "python.formatting.provider": "yapf",
  "python.formatting.yapfPath": "/opt/homebrew/Caskroom/mambaforge/base/bin/yapf",
  "python.languageServer": "Jedi",
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.terminal.executeInFileDir": true,
  "python.testing.autoTestDiscoverOnSaveEnabled": false,
  "jupyter.alwaysScrollOnNewCell": true,
  "jupyter.askForKernelRestart": false,
  "jupyter.exportWithOutputEnabled": true,
  "jupyter.jupyterServerType": "local",
  "jupyter.magicCommandsAsComments": true,
  "jupyter.pythonExportMethod": "nbconvert",
  "jupyter.sendSelectionToInteractiveWindow": true,
  "jupyter.variableQueries": [
    {
      "language": "python",
      "query": "_rwho_ls = %who_ls/nprint(_rwho_ls)",
      "parseExpr": "'(/w+)'"
    },
    {
      "language": "julia",
      "query": "whos",
      "parseExpr": "'(/w+)'"
    }
  ],
  "css.format.enable": true,
  "css.format.spaceAroundSelectorSeparator": true,
  "[c][cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },
  "[html][css][markdown][yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript][javascriptreact][typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.python"
  },
  "[json][jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[shellscript]": {
    "files.eol": "\n",
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  "[latex][tex]": {
    "editor.defaultFormatter": "James-Yu.latex-workshop"
  },
